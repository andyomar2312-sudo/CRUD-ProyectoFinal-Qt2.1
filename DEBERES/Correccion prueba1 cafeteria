
apellido = "Martinez"   
nombre = "Daniela"      
while True:
    usuario = input("Ingrese usuario (apellido): ")
    clave = input("Ingrese contraseña (nombre): ")
    if usuario == apellido and clave == nombre:
        print(" Acceso concedido")
        break
    else:
        print("Usuario o contraseña incorrectos, por favor intente de nuevo")
while True:
    print("--- MENÚ CAFETERIA EPN---")
    print("1. Sanduche + jugo : $3.50")
    print("2. Empanada + gaseosa: $2.75")
    print("3. Pastel + café: $4.00")
    print("4. Salir")
    combo = int(input("Ingrese un combo: "))
    match combo:
        case 1:
            precio = 3.50
            nombre_combo = "Sanduche + jugo"
        case 2:
            precio = 2.75
            nombre_combo = "Empanada + gaseosa"
        case 3:
            precio = 4.00
            nombre_combo = "Pastel + café"
        case 4:
            print(" Saliendo...")
            break
        case _:
            print(" Opción inválida")
            continue
    print(f"Usted ha elegido: {nombre_combo}")
    cantidad = int(input("Cantidad: "))
    subtotal = cantidad * precio
    print("Subtotal:", subtotal)
    print("Método de pago:")
    print("1. Efectivo")
    print("2. Tarjeta")
    print("3. De Una")
    pago = int(input("Seleccione: "))
    match pago:
        case 1:
            descuento = subtotal * 0.08
            total = subtotal - descuento
            print("Cliente:", usuario)
            print("Pago: Efectivo")
            print("Descuento:", descuento, "(8%)")
            print("Total:", total)
        case 2:
            recargo = subtotal * 0.12
            total = subtotal + recargo
            print("Cliente:", usuario)
            print("Pago: Tarjeta")
            print("Recargo:", recargo, "(12%)")
            print("Total:", total)
        case 3:
            descuento = subtotal * 0.05
            total = subtotal - descuento
            print("Cliente:", usuario)
            print("Pago: De Una")
            print("Descuento:", descuento, "(5%)")
            print("Total:", total)
        case _:
            print(" Método de pago inválido, por favor ingrese un método válido ")
        